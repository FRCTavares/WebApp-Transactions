# Backend API URL used by the frontend.
# For normal Mac-only local use:
VITE_API_BASE_URL=http://localhost:8000

# For iPhone testing on the same Wi-Fi, replace the IP with your Mac local IP:
# VITE_API_BASE_URL=http://192.168.1.50:8000

# Supabase Auth configuration.
# Use the public project URL and anon/publishable key from Supabase.
# Do not put service-role keys or secrets in frontend env files.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key

# Set to the literal string "true" to enable real Supabase sign-in.
# Any other value (or omitting it) hides the login screen, but the
# backend's local-auth bypass was removed - every API call will get a
# 401 without a real Supabase session. In practice this means the
# backend needs real Supabase config even for "local" use. See
# docs/auth-options.md for the current state and the one exception
# (Playwright's e2e suite mints a real Supabase-shaped JWT locally).
VITE_SUPABASE_AUTH_ENABLED=true

# Shown on the Settings > Privacy page as the contact for privacy
# requests. Public value - no credentials. Defaults to "the deployment
# owner" if unset.
VITE_PRIVACY_CONTACT_EMAIL=you@example.com

# For Vercel production, set these in the Vercel dashboard:
# VITE_API_BASE_URL=https://your-render-backend.onrender.com
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key
# VITE_SUPABASE_AUTH_ENABLED=true
# VITE_PRIVACY_CONTACT_EMAIL=you@example.com
