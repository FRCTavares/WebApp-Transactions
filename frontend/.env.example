# Backend API URL used by the frontend.
# For normal Mac-only local use:
VITE_API_BASE_URL=http://localhost:8000

# For iPhone testing on the same Wi-Fi, replace the IP with your Mac local IP:
# VITE_API_BASE_URL=http://192.168.1.50:8000

# Supabase Auth configuration.
# Use the public project URL and anon/publishable key from Supabase.
# Do not put service-role keys or secrets in frontend env files.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key

# For Vercel production, set these in the Vercel dashboard:
# VITE_API_BASE_URL=https://your-render-backend.onrender.com
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-public-anon-or-publishable-key
