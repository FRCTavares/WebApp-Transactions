# See docs/deployment.md for the full environment variable reference,
# and render.yaml for the exact production configuration.

# --- Database ---
# Omit for local SQLite (defaults to backend/data/finance.db).
# Required in production (APP_ENV=production).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Supabase Auth ---
# Required in production. Locally, omit both to run with auth disabled
# (see docs/auth-options.md for what that means).
# SUPABASE_URL=https://your-project-ref.supabase.co
# Preferred: leave SUPABASE_JWKS_URL unset - it's derived automatically
# from SUPABASE_URL. Only set it to override that derivation.
# SUPABASE_JWKS_URL=
# Legacy path: only needed if your Supabase project still issues HS256
# JWTs (older projects). Never required alongside JWKS.
# SUPABASE_JWT_SECRET=
# Required only for the account-deletion flow (docs/privacy.md). Backend
# only - never expose this to the frontend.
# SUPABASE_SERVICE_ROLE_KEY=

# --- Authorization ---
# Required in production. Comma-separated emails.
# ALLOWED_USER_EMAILS=you@example.com
# ADMIN_USER_EMAILS=you@example.com

# --- CORS ---
# Comma-separated origins. Defaults to the local Vite dev server if unset.
# Must not contain * in production.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- App environment ---
# development (default) or production. Production enables stricter
# validation - see app/config.py:validate_production_config.
# APP_ENV=development

# Defaults to false locally; must be false in production.
# LOCAL_NETWORK_ONLY=false

# Defaults to enabled outside production, disabled in production.
# API_DOCS_ENABLED=true

# --- Operational timeout policy ---
MARKET_DATA_TIMEOUT_SECONDS=15
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_STATEMENT_TIMEOUT_MS=30000
