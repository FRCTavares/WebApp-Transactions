# Application environment.
# Use APP_ENV=production on Render.
# Production mode fails startup if required security settings are missing.
APP_ENV=development

# Optional database URL.
# Defaults to local SQLite at backend/data/finance.db when unset.
# For Supabase/Render production, set this to the Postgres connection string.
# Do not commit the real production value.
# Example:
# DATABASE_URL=postgresql://postgres:password@host:5432/postgres
# DATABASE_URL=sqlite:///backend/data/finance.db

# Comma-separated frontend origins allowed to call the FastAPI backend.
# Local example:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production example:
# CORS_ORIGINS=https://web-app-transactions.vercel.app

# Supabase Auth.
# In production, set SUPABASE_URL so the backend can verify Supabase JWTs via JWKS.
# Example:
# SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_URL=

# Optional email allowlist.
# In production, keep this set to the Google accounts allowed to use the app.
# Example:
# ALLOWED_USER_EMAILS=you@example.com,family@example.com
ALLOWED_USER_EMAILS=

# Comma-separated emails allowed to mutate shared global data.
# In production, set this to the Google accounts allowed to manage market prices.
# Every admin email should also appear in ALLOWED_USER_EMAILS.
# Example:
# ADMIN_USER_EMAILS=you@example.com
ADMIN_USER_EMAILS=

# Optional local access token.
# Legacy/local-only fallback used when Supabase auth is not configured.
# When set, all /api routes except /api/health require this value in X-App-Access-Token.
# Do not use this as the main production auth mechanism.
APP_ACCESS_TOKEN=change-me-local-token

# Optional strict local-network guard.
# When true, backend requests are accepted only from localhost/private LAN clients.
# Useful when running on 0.0.0.0 for Mac/iPhone LAN testing.
# Must be false on Render.
LOCAL_NETWORK_ONLY=false
